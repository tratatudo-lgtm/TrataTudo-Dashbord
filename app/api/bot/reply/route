function isYes(txt: string) {
  const t = txt.toLowerCase().trim();
  return ["sim", "s", "ok", "confirmo", "confirmar", "certo", "isso"].includes(t);
}

function isNo(txt: string) {
  const t = txt.toLowerCase().trim();
  return ["não", "nao", "n", "nop", "errado"].includes(t);
}

function guessCertType(txt: string) {
  const t = txt.toLowerCase();
  if (t.includes("resid")) return "Residência";
  if (t.includes("morad")) return "Residência";
  if (t.includes("trabal")) return "Trabalho";
  if (t.includes("agreg")) return "Agregado";
  return null;
}

