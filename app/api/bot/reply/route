import { NextResponse } from 'next/server';
import { createClient } from '@/lib/supabase/server';
import { getSystemBasePrompt, mergePrompts } from '@/lib/promptBase';

function isValidApiKey(req: Request) {
  const key = req.headers.get('x-tratatudo-key') || '';
  const expected = process.env.TRATATUDO_API_KEY || '';
  return expected.length > 0 && key === expected;
}

type GroqMsg = { role: 'system' | 'user' | 'assistant'; content: string };

function safeStr(v: any) {
  if (v === null || v === undefined) return '';
  return String(v);
}

function toRole(direction: string) {
  const d = (direction || '').toLowerCase();
  if (d === 'in' || d === 'inbound' || d === 'user') return 'user';
  return 'assistant';
}

export async function POST(req: Request) {
  const supabase = createClient();

  try {
    // Auth: API key (server-to-server) OU sessão (dashboard)
    const apiKeyOk = isValidApiKey(req);
    const { data: { session } } = await supabase.auth.getSession();

    if (!apiKeyOk && !session) {
      return NextResponse.json({ ok: false, error: 'Não autorizado' }, { status: 401 });
    }

    const body = await req.json();
    const client_id = Number(body.client_id);
    const phone_e164 = safeStr(body.phone_e164 || '').trim();
    const text = safeStr(body.text || '').trim();

    if (!client_id || !phone_e164 || !text) {
      return NextResponse.json(
        { ok: false, error: 'client_id, phone_e164 e text são obrigatórios' },
        { status: 400 }
      );
    }

    // 1) Buscar client prompt + instance_name
    const { data: client, error: cErr } = await supabase
      .from('clients')
      .select('id, bot_instructions, company_name, instance_name, production_instance_name')
      .eq('id', client_id)
      .single();

    if (cErr) throw cErr;

    const instanceName =
      safeStr((client as any)?.production_instance_name).trim() ||
      safeStr((client as any)?.instance_name).trim() ||
      'TrataTudo bot';

    // 2) Buscar base prompt global
    const base = await getSystemBasePrompt();
    const finalPrompt = mergePrompts(base, safeStr(client?.bot_instructions || ''));

    if (!finalPrompt.trim()) {
      return NextResponse.json(
        { ok: false, error: 'Prompt vazio. Define SYSTEM_BASE_PROMPT ou bot_instructions.' },
        { status: 500 }
      );
    }

    // 3) Buscar contexto (últimas N mensagens) para manter raciocínio/contexto
    // Nota: usamos wa_messages (phone_e164 + instance)
    const HISTORY_LIMIT = 12;

    const { data: historyRows, error: hErr } = await supabase
      .from('wa_messages')
      .select('direction, text, created_at')
      .eq('phone_e164', phone_e164)
      .eq('instance', instanceName)
      .order('created_at', { ascending: false })
      .limit(HISTORY_LIMIT);

    if (hErr) {
      // não falha o bot por causa do histórico
      console.error('BOT REPLY: history fetch error:', hErr);
    }

    const history = Array.isArray(historyRows) ? historyRows.slice().reverse() : [];

    const messages: GroqMsg[] = [
      { role: 'system', content: finalPrompt },
      ...history
        .map((r: any) => {
          const role = toRole(r.direction) as 'user' | 'assistant';
          const content = safeStr(r.text || '').trim();
          if (!content) return null;
          return { role, content };
        })
        .filter(Boolean) as GroqMsg[],
      { role: 'user', content: text },
    ];

    // 4) Gravar a mensagem de entrada (inbound) em wa_messages
    // (não vamos falhar o pedido se a gravação falhar — mas registamos no log)
    try {
      const { error: logInErr } = await supabase.from('wa_messages').insert({
        phone_e164,
        instance: instanceName,
        direction: 'in',
        text,
        raw: {
          client_id,
          source: 'api/bot/reply',
          ts: new Date().toISOString(),
        },
      } as any);

      if (logInErr) console.error('BOT REPLY: log inbound error:', logInErr);
    } catch (e) {
      console.error('BOT REPLY: log inbound exception:', e);
    }

    // 5) Chamar Groq
    const groqKey = process.env.GROQ_API_KEY || '';
    const model = process.env.GROQ_MODEL || 'llama-3.1-8b-instant';

    if (!groqKey) {
      return NextResponse.json({ ok: false, error: 'GROQ_API_KEY em falta' }, { status: 500 });
    }

    const res = await fetch('https://api.groq.com/openai/v1/chat/completions', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        Authorization: `Bearer ${groqKey}`,
      },
      body: JSON.stringify({
        model,
        temperature: 0.2,
        messages,
      }),
    });

    const raw = await res.text();
    let data: any;
    try { data = JSON.parse(raw); } catch { data = null; }

    if (!res.ok || !data) {
      return NextResponse.json(
        { ok: false, error: 'Erro ao chamar Groq', debug: raw?.slice(0, 800) },
        { status: 500 }
      );
    }

    const reply = safeStr(data?.choices?.[0]?.message?.content || '').trim();

    // 6) Gravar a resposta (outbound) em wa_messages
    try {
      const { error: logOutErr } = await supabase.from('wa_messages').insert({
        phone_e164,
        instance: instanceName,
        direction: 'out',
        text: reply,
        raw: {
          client_id,
          source: 'api/bot/reply',
          model,
          ts: new Date().toISOString(),
        },
      } as any);

      if (logOutErr) console.error('BOT REPLY: log outbound error:', logOutErr);
    } catch (e) {
      console.error('BOT REPLY: log outbound exception:', e);
    }

    return NextResponse.json({
      ok: true,
      data: {
        client_id,
        phone_e164,
        instance: instanceName,
        reply,
      },
    });
  } catch (err: any) {
    console.error('BOT REPLY error:', err);
    return NextResponse.json(
      { ok: false, error: err?.message || 'Erro interno' },
      { status: 500 }
    );
  }
}